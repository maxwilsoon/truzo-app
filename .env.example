# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
#
# EXPO_PUBLIC_ variables are embedded in the JS bundle by Metro.
# The Supabase anon key is a publishable key (like Stripe's pk_live_*) —
# it is safe in the bundle because all data access is protected by RLS.
#
# For EAS cloud builds, set these via EAS Secrets instead of .env.local:
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_URL --value "..."
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_ANON_KEY --value "..."
#   eas secret:create --scope project --name EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY --value "..."
#
# Dev auto-login credentials are gated by __DEV__ — Metro removes them from
# production bundles entirely via dead-code elimination.

# ── Supabase (required) ──────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe (required when payment integration is added) ──────────────────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here

# ── Dev auto-login (optional) ────────────────────────────────────────────────
# Set to a child account for fast iteration during local development.
# Leave blank to disable auto-login (normal login screen will appear).
# Never set these in a production or staging environment.
EXPO_PUBLIC_DEV_CHILD_USERNAME=
EXPO_PUBLIC_DEV_CHILD_PASSWORD=
